{
  "experiment_name": "pricing_page",
  "method": "bayesian",
  "primary_metric": "arpu",
  "alpha": 0.05,
  "look_index": 1,
  "max_looks": 1,
  "columns": {
    "variant": "variant_name",
    "visitors": "users",
    "conversions": "orders",
    "revenue_sum": "revenue_sum",
    "revenue_sum_squares": "revenue_sum_squares",
    "is_control": "is_control"
  },
  "decision_thresholds": {
    "bayes_prob_beats_control": 0.9,
    "max_expected_loss": 0.2
  },
  "samples": 20000,
  "random_seed": 7
}
